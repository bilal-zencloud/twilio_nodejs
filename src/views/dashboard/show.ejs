<%- include('../partials/header') %>

<p><a href="/dashboard">&larr; Back to leads</a></p>

<div class="card">
  <h2>Lead #<%= lead.id %></h2>
  <dl>
    <dt>Phone</dt>   <dd><%= lead.caller_phone %></dd>
    <dt>Status</dt>  <dd><span class="badge badge-<%= lead.status %>"><%= lead.status %></span></dd>
    <dt>Name</dt>    <dd><%= lead.name || '—' %></dd>
    <dt>Email</dt>   <dd><%= lead.email || '—' %></dd>
    <dt>Need</dt>    <dd><%= lead.need_summary || '—' %></dd>
    <dt>Call SID</dt><dd class="meta"><%= lead.call_sid || '—' %></dd>
    <dt>Created</dt> <dd class="meta"><%= lead.created_at %></dd>
    <dt>Updated</dt> <dd class="meta"><%= lead.updated_at %></dd>
  </dl>
</div>

<div class="card">
  <h2>Conversation</h2>
  <% if (messages.length === 0) { %>
    <p class="empty">No messages yet.</p>
  <% } else { %>
    <ul class="conversation">
      <% messages.forEach(function(msg) { %>
        <li class="<%= msg.direction %>">
          <%= msg.body %>
          <span class="time"><%= msg.direction %> · <%= msg.created_at %></span>
        </li>
      <% }); %>
    </ul>
  <% } %>
</div>

<%- include('../partials/footer') %>
