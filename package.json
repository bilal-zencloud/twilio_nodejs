{
  "name": "twilio_nodejs",
  "version": "1.0.0",
  "description": "Missed-call capture loop with Twilio SMS, Anthropic AI, and Next.js dashboard",
  "main": "index.js",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:frontend\"",
    "dev:api": "nodemon index.js",
    "dev:frontend": "npm run dev --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "setup:twilio": "node scripts/setup-twilio-webhooks.js",
    "verify:caller": "node scripts/verify-caller.js",
    "check:sms": "node scripts/check-sms-delivery.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@aws-sdk/client-s3": "^3.1079.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.11.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "twilio": "^6.0.2"
  }
}
