# Server
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# SQLite database file path
DATABASE_PATH=./data/leads.db

# Multi-tenant demo account (single business)
DEFAULT_ACCOUNT_ID=demo-account-1
# Business name: edit config/business.json

# Twilio credentials (used by the app and npm run setup:twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Optional: use SID directly if you know it (PNxxxxxxxx)
# TWILIO_PHONE_NUMBER_SID=

# Optional: Messaging Service SID after A2P 10DLC registration
# TWILIO_MESSAGING_SERVICE_SID=
TWILIO_VALIDATE_SIGNATURE=false

# Anthropic API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# AWS S3 — photo storage (private bucket; dashboard views via authenticated API proxy)
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# Admin dashboard authentication
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRY=7d
SESSION_INACTIVITY_MINUTES=15
# Seeded on first run only — change your password from the dashboard after logging in
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
